local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local player = Players.LocalPlayer
local gravityNormal = workspace.Gravity
local isRunning = false
local speed = 375
local currentTween = nil
local destinations = {
    CFrame.new(-43.6134491, 62.1137619, 672.744934, -0.999842644, -0.00183729955, 0.017645346, 0, 0.994622767, 0.103564225, -0.0177407414, 0.103547923, -0.994466245),
    CFrame.new(-60.1504707, 97.4659729, 8767.91406, -0.99889338, 0.000705028593, 0.0470264405, 0, 0.999887645, -0.0149902813, -0.047031723, -0.0149736926, -0.998781145),
    CFrame.new(-54.331871, -345.398346, 9488.60645, -0.98221302, 0, 0.187770084, 0, 1, 0, -0.187770084, 0, -0.98221302),
}

-- Глобальный флаг для полной остановки фоновых процессов персонажа
local isScriptAlive = true

-- Создание UI 
local screenGui = Instance.new("ScreenGui", game.CoreGui)
screenGui.Name = "AutoFarmUI"
screenGui.ResetOnSpawn = false

local menu = Instance.new("Frame")
menu.Size = UDim2.fromOffset(260, 185) 
menu.Position = UDim2.new(0.5, -130, 0.4, -92)
menu.BackgroundColor3 = Color3.fromRGB(30, 30, 36)
menu.BorderSizePixel = 0
menu.Active = true
menu.Draggable = true
menu.Parent = screenGui

local menuCorner = Instance.new("UICorner")
menuCorner.CornerRadius = UDim.new(0, 10)
menuCorner.Parent = menu

-- Заголовок меню
local title = Instance.new("TextLabel")
title.Size = UDim2.new(0.6, 0, 0, 28)
title.Position = UDim2.new(0.08, 0, 0, 8)
title.BackgroundTransparency = 1
title.Text = "AutoFarm Panel"
title.TextColor3 = Color3.fromRGB(220, 220, 225)
title.Font = Enum.Font.Gotham
title.TextSize = 14
title.TextXAlignment = Enum.TextXAlignment.Left
title.Parent = menu

-- Кнопка закрытия интерфейса (X)
local close = Instance.new("TextButton")
close.Size = UDim2.new(0, 28, 0, 28)
close.Position = UDim2.new(1, -36, 0, 8)
close.Text = "×"
close.Font = Enum.Font.Gotham
close.TextSize = 22
close.BackgroundColor3 = Color3.fromRGB(60, 60, 65)
close.TextColor3 = Color3.new(1, 1, 1)
close.Parent = menu

local closeCorner = Instance.new("UICorner")
closeCorner.CornerRadius = UDim.new(0, 6)
closeCorner.Parent = close

-- Кнопка Старт / Стоп
local toggle = Instance.new("TextButton")
toggle.Size = UDim2.new(0.86, 0, 0.32, 0)
toggle.Position = UDim2.new(0.07, 0, 0.28, 0)
toggle.Text = "Start AutoFarm"
toggle.Font = Enum.Font.Gotham
toggle.TextSize = 15
toggle.BackgroundColor3 = Color3.fromRGB(58, 134, 255)
toggle.TextColor3 = Color3.new(1, 1, 1)
toggle.Parent = menu

local toggleCorner = Instance.new("UICorner")
toggleCorner.CornerRadius = UDim.new(0, 8)
toggleCorner.Parent = toggle

-- Кнопка ПОЛНОГО УНИЧТОЖЕНИЯ Скрипта
local destroyBtn = Instance.new("TextButton")
destroyBtn.Size = UDim2.new(0.86, 0, 0.26, 0)
destroyBtn.Position = UDim2.new(0.07, 0, 0.66, 0)
destroyBtn.Text = "Destroy Script"
destroyBtn.Font = Enum.Font.Gotham
destroyBtn.TextSize = 13
destroyBtn.BackgroundColor3 = Color3.fromRGB(230, 50, 50)
destroyBtn.TextColor3 = Color3.new(1, 1, 1)
destroyBtn.Parent = menu

local destroyCorner = Instance.new("UICorner")
destroyCorner.CornerRadius = UDim.new(0, 8)
destroyCorner.Parent = destroyBtn


-- Функция полной очистки и вырубания кода
local function selfDestroy()
    isScriptAlive = false
    isRunning = false
    workspace.Gravity = gravityNormal
    if currentTween then currentTween:Cancel() end
    screenGui:Destroy()
end

close.MouseButton1Click:Connect(selfDestroy)
destroyBtn.MouseButton1Click:Connect(selfDestroy)

local function moveTo(targetCFrame, setGravity)
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local distance = (root.Position - targetCFrame.Position).Magnitude
    local duration = distance / speed
    currentTween = TweenService:Create(root, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
    currentTween:Play()
    local reached = false
    currentTween.Completed:Connect(function()
        reached = true
    end)
    if setGravity then
        workspace.Gravity = gravityNormal
    else
        workspace.Gravity = 0
    end
    while not reached and isRunning and isScriptAlive do
        RunService.Heartbeat:Wait()
    end
end

task.spawn(function()
    while isScriptAlive do
        task.wait(10)
        if isRunning and isScriptAlive then
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.K, false, game)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.K, false, game)
        end
    end
end)

local function autoFarmLoop()
    while isRunning and isScriptAlive do
        local char = player.Character or player.CharacterAdded:Wait()
        local root = char:WaitForChild("HumanoidRootPart", 5)
        if not root then return end
        for i, cf in ipairs(destinations) do
            if not isRunning or not isScriptAlive then return end
            moveTo(cf, i == #destinations)
        end
        if isScriptAlive then
            repeat wait(1) until player.CharacterAdded:Wait() or not isScriptAlive
        end
    end
end

toggle.MouseButton1Click:Connect(function()
    if not isScriptAlive then return end
    isRunning = not isRunning
    if not isRunning then
        toggle.Text = "Start AutoFarm"
        toggle.BackgroundColor3 = Color3.fromRGB(58, 134, 255)
        workspace.Gravity = gravityNormal
        if currentTween then currentTween:Cancel() end
    else
        toggle.Text = "Stop AutoFarm"
        toggle.BackgroundColor3 = Color3.fromRGB(46, 196, 182)
        task.spawn(autoFarmLoop)
    end
end)

player.CharacterAdded:Connect(function()
    if isRunning and isScriptAlive then
        task.spawn(autoFarmLoop)
    end
end)

player.CharacterAdded:Connect(function()
    if isRunning and isScriptAlive then
        local char = player.Character or player.CharacterAdded:Wait()
        local root = char:WaitForChild("HumanoidRootPart", 5)
        if root and isScriptAlive then
            wait(1)
            if isScriptAlive then
                moveTo(destinations, false)
                task.spawn(autoFarmLoop)
            end
        end
    end
end)
